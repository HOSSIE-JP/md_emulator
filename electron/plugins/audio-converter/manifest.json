{
  "id": "audio-converter",
  "name": "音声変換コンバーター",
  "description": "WAV/MP3/OGG を WAV へ変換し、トリミング・正規化・音量調整・モノラル化・周波数変換を提供します。",
  "version": "1.0.0",
  "types": ["converter"],
  "permissions": ["project.read", "project.write", "res.write", "main.invokeHook"],
  "hooks": ["convertAudio"],
  "mainApi": {
    "hooks": ["convertAudio"],
    "capabilities": ["audio-convert"]
  },
  "renderer": {
    "entry": "renderer.js",
    "styles": ["style.css"],
    "capabilities": ["audio-convert-ui"]
  }
}
