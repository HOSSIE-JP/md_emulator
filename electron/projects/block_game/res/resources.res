// ボール
SPRITE spr_ball sprite/spr_ball.png 1 1 NONE 0 NONE BALANCED FAST FALSE
// パドル
SPRITE spr_paddle sprite/spr_paddle.png 4 1 NONE 0 NONE BALANCED FAST FALSE
// パワーアップ：マルチボール
SPRITE spr_powerup_multi_ball sprite/spr_powerup_multi_ball.png 2 1 NONE 0 NONE BALANCED FAST FALSE
// パワーアップ：ストロング
SPRITE spr_powerup_strong sprite/spr_powerup_strong.png 2 1 NONE 0 NONE BALANCED FAST FALSE
// パワーアップ：スピードアップ
SPRITE spr_powerup_speed_up sprite/spr_powerup_speed_up.png 2 1 NONE 0 NONE BALANCED FAST FALSE
// パワーアップ：バリア
SPRITE spr_powerup_barrier sprite/spr_powerup_barrier.png 2 1 NONE 0 NONE BALANCED FAST FALSE
// ブロック：白
SPRITE spr_block_white sprite/spr_block_white.png 2 1 NONE 0 NONE BALANCED FAST FALSE
// ブロック：黄
SPRITE spr_block_yellow sprite/spr_block_yellow.png 2 1 NONE 0 NONE BALANCED FAST FALSE
// ブロック：緑
SPRITE spr_block_green sprite/spr_block_green.png 2 1 NONE 0 NONE BALANCED FAST FALSE
// ブロック：青
SPRITE spr_block_blue sprite/spr_block_blue.png 2 1 NONE 0 NONE BALANCED FAST FALSE
// ブロック：グレー
SPRITE spr_block_gray sprite/spr_block_gray.png 2 1 NONE 0 NONE BALANCED FAST FALSE
// ハイスコア画面
IMAGE img_high_score_screen gfx/img_high_score_screen.png NONE ALL 0
// ゲームオーバー画面
IMAGE img_game_over_screen gfx/img_game_over_screen.png NONE ALL 0
// タイトル画面
IMAGE img_title_screen gfx/img_title_screen.png NONE ALL 0
// ロゴ画面1
IMAGE img_logo_screen_1 gfx/img_logo_screen_1.png NONE ALL 0
// ロゴ画面2
IMAGE img_logo_screen_2 gfx/img_logo_screen_2.png NONE ALL 0
// ボールが壁に当たる
WAV se_ball_hit_wall sfx/se_ball_hit_wall.wav XGM2 6650 TRUE
// ブロック破壊
WAV se_block_break sfx/se_block_break.wav XGM2 6650 TRUE
// ゲーム開始
WAV se_game_start sfx/se_game_start.wav XGM2 6650 TRUE
// パワーアップ出現
WAV se_powerup_appear sfx/se_powerup_appear.wav XGM2 6650 TRUE
// パワーアップ取得
WAV se_powerup_get sfx/se_powerup_get.wav XGM2 6650 TRUE
// ボールがパドルにあたる
WAV se_ball_hit_paddle sfx/se_ball_hit_paddle.wav XGM2 6650 TRUE
// ゲームオーバー
WAV se_game_over sfx/se_game_over.wav XGM2 6650 TRUE
// ボール落下（ミス）
WAV se_ball_lose sfx/se_ball_lose.wav XGM2 6650 TRUE
// ポーズ
WAV se_pause sfx/se_pause.wav XGM2 6650 TRUE
// ステージクリア
WAV se_stage_clear sfx/se_stage_clear.wav XGM2 6650 TRUE
// ボーナス得点加算
WAV se_bonus_count sfx/se_bonus_count.wav XGM2 6650 TRUE
// システムフォント
TILESET font_system font/font_system.png NONE ALL ROW FALSE
// システムフォント PAL0
PALETTE font_system_palette font/font_system.png
// BGM
WAV bgm_001 bgm/bgm_001.wav XGM2 6650 TRUE
// BGM
WAV bgm_002 bgm/bgm_002.wav XGM2 6650 TRUE
// BGM
WAV bgm_003 bgm/bgm_003.wav XGM2 6650 TRUE
// BGM
WAV bgm_004 bgm/bgm_004.wav XGM2 6650 TRUE
// ステージ背景
IMAGE stage_bg_stage1 stage/stage_bg_stage1.png NONE ALL 0
// ステージ背景
IMAGE stage_bg_stage2 stage/stage_bg_stage2.png NONE ALL 0
// ステージ背景
IMAGE stage_bg_stage3 stage/stage_bg_stage3.png NONE ALL 0
// ステージ背景
IMAGE stage_bg_stage4 stage/stage_bg_stage4.png NONE ALL 0
